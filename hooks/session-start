#!/usr/bin/env bash
# SessionStart hook: auto-installs and authenticates agentiqa CLI
set -euo pipefail

messages=()

# 1. Auto-install agentiqa CLI if missing
if ! command -v agentiqa &>/dev/null; then
  if npm install -g agentiqa &>/dev/null; then
    messages+=("Agentiqa CLI installed successfully.")
  else
    messages+=("⚠️ Could not auto-install agentiqa CLI. Run: npm install -g agentiqa (may need sudo)")
  fi
fi

# 2. Check authentication and prompt login if needed
if command -v agentiqa &>/dev/null; then
  if ! agentiqa whoami &>/dev/null; then
    messages+=("Agentiqa requires authentication. Running 'agentiqa login'...")
    if agentiqa login 2>/dev/null; then
      messages+=("Agentiqa login successful.")
    else
      messages+=("⚠️ Agentiqa login failed or timed out. Run manually: agentiqa login")
    fi
  fi
fi

# If nothing to report, exit silently
if [ ${#messages[@]} -eq 0 ]; then
  echo '{}'
  exit 0
fi

msg=$(printf '%s\n' "${messages[@]}")

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

escaped=$(escape_for_json "$msg")

if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
fi

exit 0
